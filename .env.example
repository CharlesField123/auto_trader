# Copy to .env for local development:  cp .env.example .env
# main.py auto-loads .env via python-dotenv on startup.
# In production these are set in the Railway dashboard, never committed.

# Supabase — use the SERVICE ROLE key so RLS does not block reads.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Alpaca Paper Trading — generate at https://alpaca.markets (Paper section).
ALPACA_API_KEY=your-alpaca-paper-key
ALPACA_SECRET_KEY=your-alpaca-paper-secret

# Discord webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# --- Risk management (applies to both modes) ---------------------------------
MAX_RISK_PCT=0.01            # max account risk per trade (1%)
DEFAULT_STOP_PCT=0.05        # fallback stop for daily stock signals lacking one
DAILY_DRAWDOWN_HALT_PCT=0.03  # circuit breaker: halt new entries at -3% on the day
MIN_PRICE=0.01
MAX_OPEN_POSITIONS=5         # max concurrent positions (diversification cap)
MAX_GROSS_EXPOSURE_PCT=0.50  # max total capital deployed across positions (50%)
MAX_POSITION_PCT=0.10        # max single-position notional (10% of equity)
MIN_NOTIONAL=1.0             # skip orders below this $ notional (Alpaca crypto min)

# --- Crypto scanner (python main.py --crypto), runs 24/5 ---------------------
# Alpaca has no futures; crypto is its only 24/7 asset class, so the always-on
# scanner trades crypto pairs (Alpaca "BASE/QUOTE" format).
CRYPTO_UNIVERSE=BTC/USD,ETH/USD,SOL/USD,LTC/USD,BCH/USD,AVAX/USD,LINK/USD,UNI/USD,DOGE/USD
CRYPTO_TOP_N=3              # how many of the best-ranked pairs to trade
SCAN_LOOKBACK_BARS=20       # 1-min bars examined per scan
CRYPTO_MIN_SCORE=0.0008     # momentum×volume score a pair must clear to trade
CRYPTO_STOP_LOSS_PCT=0.01   # close a position down this much (stop-loss)
CRYPTO_TAKE_PROFIT_PCT=0.02  # close a position up this much (take-profit)
REENTRY_COOLDOWN_MIN=15     # minutes before re-entering a just-closed symbol
STATUS_UPDATE_MIN=60        # minutes between Discord P&L / account-size updates
