# Copy to .env for local development:  cp .env.example .env
# main.py auto-loads .env via python-dotenv on startup.
# In production these are set in the Railway dashboard, never committed.

# Supabase — use the SERVICE ROLE key so RLS does not block reads.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Alpaca Paper Trading — generate at https://alpaca.markets (Paper section).
ALPACA_API_KEY=your-alpaca-paper-key
ALPACA_SECRET_KEY=your-alpaca-paper-secret

# Discord webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Optional risk tuning (defaults shown).
MAX_RISK_PCT=0.01
DEFAULT_STOP_PCT=0.05
DAILY_DRAWDOWN_HALT_PCT=0.03
MIN_PRICE=0.01

# --- Futures scanner (python main.py --futures) ------------------------------
# Symbols to scan on 1-minute bars. Defaults to liquid futures-tracking ETF
# proxies (tradable on Alpaca paper today). Swap in native futures roots
# (e.g. MES,MNQ,MYM,M2K,MGC,MCL) when running against a feed that serves them.
FUTURES_UNIVERSE=SPY,QQQ,IWM,DIA,GLD,SLV,USO,UNG,TLT
FUTURES_TOP_N=3            # how many of the best-ranked symbols to trade
SCAN_LOOKBACK_BARS=20      # 1-min bars examined per scan
FUTURES_MIN_SCORE=0.0008   # momentum×volume score a symbol must clear to trade
STOP_ATR_MULT=1.5          # stop distance = this × average 1-min range
